{
  "$schema": "<https://json-schema.org/draft/2020-12/schema>",
  "$id": "<https://github.com/Bruiserhq/tacit/spec/brand-context.schema.json>",
  "title": "Brand Context Protocol v0.1",
  "description": "JSON Schema stub for validating BCP file frontmatter and structured blocks. v0.1 covers required frontmatter fields and canonical structured-block shapes. Full coverage ships with v0.2.",
  "type": "object",
  "properties": {
    "bcp_version": {
      "type": "string",
      "pattern": "^\\\\d+\\\\.\\\\d+$",
      "description": "Spec compliance version."
    },
    "tree_version": {
      "type": "string",
      "pattern": "^\\\\d+\\\\.\\\\d+\\\\.\\\\d+$",
      "description": "Semver version of this brand's published BCP tree."
    },
    "brand_name": {
      "type": "string",
      "minLength": 1
    },
    "file_type": {
      "type": "string",
      "enum": ["root", "voice", "visual", "values", "boundaries", "claims", "representation", "audience", "product", "campaign"]
    },
    "last_updated": {
      "type": "string",
      "format": "date"
    },
    "revision": {
      "type": "string",
      "description": "Optional content hash suitable for HTTP ETag caching."
    },
    "default_locale": {
      "type": "string",
      "pattern": "^[a-z]{2}(-[A-Z]{2})?$"
    },
    "supported_locales": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z]{2}(-[A-Z]{2})?$"
      }
    },
    "daughter_files": {
      "type": "object",
      "description": "Registry of daughter file paths. Root only.",
      "additionalProperties": true
    }
  },
  "required": ["bcp_version", "brand_name", "file_type", "last_updated"]
}
